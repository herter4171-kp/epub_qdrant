# Qdrant server URL
QDRANT_URL=http://192.168.68.75:6333

# Unified embedding server
EMBEDDING_SERVER_URL=http://192.168.68.75:8100
EMBEDDING_SERVER_PORT=8100

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Semantic chunking — path to the embeddinggemma-300m tokenizer.json
TOKENIZER_JSON=/path/to/tokenizer.json

# Qdrant vector config (should match embedding model output)
VECTOR_SIZE=768
DISTANCE=Cosine

# ── LiteLLM / LLM settings ──────────────────────────────────────────
LITELLM_API_URL=https://litellm.twr.church/v1
LITELLM_API_KEY=
LITELLM_MODEL=qwen36

# Context window size in tokens for the LLM.
# Reasoning trace + prompt + reply must all fit within this budget.
# Default: 128000 (Qwen3.6 recommended minimum for thinking mode)
LITELLM_CONTEXT_WINDOW=128000

# Maximum tokens reserved for the thinking/reasoning trace on models
# with thinking mode (e.g. Qwen3/3.6). The reply budget = context_window
# - max_thinking_tokens - estimated_prompt_tokens.
# Default: 8192 (adjust lower if you see blank replies due to
# reasoning consuming all context space)
LITELLM_MAX_THINKING_TOKENS=64000
